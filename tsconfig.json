{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": ["ES2023", "DOM", "DOM.Iterable"]
  },
  "exclude": [
    "node_modules",
    "**/node_modules",
    "**/dist",
    "**/.output",
    "**/.nuxt",
    "**/target"
  ]
}
