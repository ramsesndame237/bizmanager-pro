# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=bizmanager
POSTGRES_USER=bizmanager
POSTGRES_PASSWORD=bizmanager_secret
POSTGRES_PORT=5432
DATABASE_URL="postgresql://bizmanager:bizmanager_secret@localhost:5432/bizmanager?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL="redis://:redis_secret@localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET=change_me_to_a_very_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret_key
MINIO_ENDPOINT=localhost
MINIO_USE_SSL=false
MINIO_BUCKET=bizmanager

# ─── PDF Engine (Rust microservice) ──────────────────────────────────────────
PDF_ENGINE_URL=http://localhost:3002
PDF_ENGINE_PORT=3002

# ─── Frontend ─────────────────────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NUXT_PUBLIC_WS_URL=ws://localhost:3001
