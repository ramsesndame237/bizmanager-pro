# ============================================================
# BizManager Pro — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://bizmanager:bizmanager@localhost:5432/bizmanager
POSTGRES_USER=bizmanager
POSTGRES_PASSWORD=bizmanager

# --- JWT ---
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- API (NestJS) ---
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000
MOBILE_URL=http://localhost:3002

# --- Web Dashboard (Nuxt) ---
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NUXT_PUBLIC_WS_URL=ws://localhost:3001

# --- PDF Engine (Rust) ---
PDF_ENGINE_PORT=8080
RUST_LOG=info

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=bizmanager
